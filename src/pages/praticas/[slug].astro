---
import { render } from "astro:content";
import PracticeLayout from "../../layouts/PracticeLayout.astro";
import { getPublishedPractices } from "../../lib/content/practices";

export async function getStaticPaths() {
  const practices = await getPublishedPractices();

  return practices.map((practice) => ({
    params: { slug: practice.slug },
    props: { practice },
  }));
}

const { practice } = Astro.props;
const { Content } = await render(practice);
---

<PracticeLayout
  title={practice.data.title}
  currentSlug={practice.slug}
>
  <Content />
</PracticeLayout>
