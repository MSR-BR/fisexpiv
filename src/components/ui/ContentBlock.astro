---
interface Props {
  id?: string;
  eyebrow?: string;
  title: string;
  description?: string;
}

const { id, eyebrow, title, description } = Astro.props;
---

<section class="content-block" id={id}>
  <div class="section-intro">
    {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
    <h2>{title}</h2>
    {description ? <p>{description}</p> : null}
  </div>
  <slot />
</section>

