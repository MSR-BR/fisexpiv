---
interface Props {
  title?: string;
}

const {
  title = "Física Experimental IV",
} = Astro.props;
---

<header class="site-hero">
  <div class="wrap hero-grid hero-grid--simple">
    <div class="hero-copy">
      <p class="eyebrow">Instituto de Física</p>
      <p class="hero-copy__institution">Universidade Federal Fluminense</p>
      <h1>{title}</h1>
    </div>
  </div>
</header>
