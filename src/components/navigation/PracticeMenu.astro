---
import { practiceCatalog } from "../../lib/content/practice-catalog";

interface Props {
  currentSlug?: string;
}

const { currentSlug } = Astro.props;
const rawBaseUrl = import.meta.env.BASE_URL;
const baseUrl = rawBaseUrl.endsWith("/") ? rawBaseUrl : `${rawBaseUrl}/`;
---

<aside class="practice-menu">
  <div class="practice-menu__header">
    <h2>Práticas</h2>
    <button
      type="button"
      class="practice-menu__toggle"
      data-practice-menu-toggle
      aria-expanded="false"
      aria-controls="practiceMenuNav"
    >
      Menu
    </button>
  </div>

  <nav id="practiceMenuNav" class="practice-menu__nav" aria-label="Lista de práticas" data-practice-menu-nav>
    <ul class="practice-menu__list">
      {practiceCatalog.map((practice, index) => {
        const isActive = practice.slug === currentSlug;
        const isAvailable = practice.status === "available";
        const className = [
          "practice-menu__item",
          isAvailable ? "is-available" : "is-planned",
          isActive ? "is-active" : "",
        ]
          .filter(Boolean)
          .join(" ");

        return (
          <li>
            {isAvailable ? (
              <a class={className} href={`${baseUrl}praticas/${practice.slug}/`} aria-current={isActive ? "page" : undefined}>
                <span class="practice-menu__number">{String(index + 1).padStart(2, "0")}</span>
                <span class="practice-menu__content">
                  <span class="practice-menu__title">{practice.title}</span>
                </span>
              </a>
            ) : (
              <span class={className} aria-disabled="true">
                <span class="practice-menu__number">{String(index + 1).padStart(2, "0")}</span>
                <span class="practice-menu__content">
                  <span class="practice-menu__title">{practice.title}</span>
                </span>
              </span>
            )}
          </li>
        );
      })}
    </ul>
  </nav>
</aside>

<script>
  const toggle = document.querySelector("[data-practice-menu-toggle]");
  const nav = document.querySelector("[data-practice-menu-nav]");

  if (toggle instanceof HTMLButtonElement && nav instanceof HTMLElement) {
    nav.dataset.open = "false";
    toggle.setAttribute("aria-expanded", "false");

    toggle.addEventListener("click", () => {
      const isOpen = nav.dataset.open === "true";
      nav.dataset.open = isOpen ? "false" : "true";
      toggle.setAttribute("aria-expanded", isOpen ? "false" : "true");
    });
  }
</script>
