---
import SiteHeader from "../components/layout/SiteHeader.astro";
import PracticeMenu from "../components/navigation/PracticeMenu.astro";
import "katex/dist/katex.min.css";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  currentSlug?: string;
}

const { title, description, currentSlug } = Astro.props;
const basePath = import.meta.env.BASE_URL.endsWith("/") ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const cloudflareWebAnalyticsToken =
  import.meta.env.PUBLIC_CLOUDFLARE_WEB_ANALYTICS_TOKEN ?? "e1d22de83aaf4bf99a92805085d39ec2";
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {cloudflareWebAnalyticsToken ? (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={JSON.stringify({ token: cloudflareWebAnalyticsToken })}
      ></script>
    ) : null}
  </head>
  <body data-project-base-path={basePath}>
    <SiteHeader title="Física Experimental IV" />
    <main class="wrap main-shell">
      <PracticeMenu currentSlug={currentSlug} />
      <div class="page-shell">
        <slot />
      </div>
    </main>
    <script>
      const body = document.body;
      const projectBasePath = body.dataset.projectBasePath ?? "/";
      const links = document.querySelectorAll("a[href]");

      links.forEach((link) => {
        const href = link.getAttribute("href");
        const forceNewTab = link.dataset.forceNewTab === "true";

        if (!href || href.startsWith("#")) {
          return;
        }

        const url = new URL(href, window.location.href);
        const isSameOrigin = url.origin === window.location.origin;
        const isInternalProjectLink = isSameOrigin && url.pathname.startsWith(projectBasePath);

        if (isInternalProjectLink && !forceNewTab) {
          link.removeAttribute("target");
          link.removeAttribute("rel");
          return;
        }

        link.setAttribute("target", "_blank");
        link.setAttribute("rel", "noopener noreferrer");
      });
    </script>
  </body>
</html>
